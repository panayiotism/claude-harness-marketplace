#!/bin/bash
# SubagentStart Hook - Context injection for harness subagents
# Scoped via hooks.json matcher to implementer/general-purpose agents so
# unrelated subagents (docs lookups, explorers) don't get feature context.
# Injects feature, verification commands, acceptance criteria, and past
# failures at spawn time.

trap 'exit 0' ERR

# Read hook input from stdin
INPUT=$(cat)

# Find project root
PROJECT_ROOT="${CLAUDE_PROJECT_DIR:-$(pwd)}"
if [ ! -d "$PROJECT_ROOT/.claude-harness" ]; then
    # Fallback: walk up from cwd
    PROJECT_ROOT="$(pwd)"
    while [ "$PROJECT_ROOT" != "/" ]; do
        [ -d "$PROJECT_ROOT/.claude-harness" ] && break
        PROJECT_ROOT="$(dirname "$PROJECT_ROOT")"
    done
fi

if [ ! -d "$PROJECT_ROOT/.claude-harness" ]; then
    echo '{}'
    exit 0
fi

CONFIG_FILE="$PROJECT_ROOT/.claude-harness/config.json"
FEATURES_FILE="$PROJECT_ROOT/.claude-harness/features/active.json"
MEMORY_DIR="$PROJECT_ROOT/.claude-harness/memory"

# Find active session dir (most recent session with loop-state)
SESSION_DIR=""
if [ -d "$PROJECT_ROOT/.claude-harness/sessions" ]; then
    for dir in "$PROJECT_ROOT/.claude-harness/sessions"/*/; do
        [ -f "${dir}loop-state.json" ] && SESSION_DIR="$dir"
    done
fi

# Build context using python3 for JSON handling
if command -v python3 >/dev/null 2>&1; then
    CONTEXT=$(python3 -c "
import json, os

context_parts = []

# 1. Active loop state (feature info, attempt count)
session_dir = '$SESSION_DIR'
if session_dir and os.path.isfile(os.path.join(session_dir, 'loop-state.json')):
    try:
        with open(os.path.join(session_dir, 'loop-state.json')) as f:
            loop = json.load(f)
        if loop.get('status') == 'in_progress':
            context_parts.append(f\"Feature: {loop.get('feature', '?')} - {loop.get('featureName', '?')}\")
            context_parts.append(f\"Attempt: {loop.get('attempt', 0)}/{loop.get('maxAttempts', 12)}\")
    except Exception:
        pass

# 2. Verification commands from config
config_file = '$CONFIG_FILE'
if os.path.isfile(config_file):
    try:
        with open(config_file) as f:
            config = json.load(f)
        v = config.get('verification', {})
        cmds = [f'{k}: {v[k]}' for k in ['build', 'tests', 'lint', 'typecheck', 'acceptance'] if v.get(k)]
        if cmds:
            context_parts.append('Verification: ' + ' | '.join(cmds))
    except Exception:
        pass

# 3. Acceptance criteria from active feature
features_file = '$FEATURES_FILE'
if os.path.isfile(features_file):
    try:
        with open(features_file) as f:
            features = json.load(f)
        for feat in features.get('features', []):
            if feat.get('status') == 'in_progress':
                criteria = feat.get('acceptanceCriteria', [])
                if criteria:
                    scenarios = [c.get('scenario', '') for c in criteria[:5]]
                    context_parts.append('Acceptance criteria: ' + '; '.join(scenarios))
                break
    except Exception:
        pass

# 4+5. Memory bundle (OKF v0.1): failures to avoid + learned rules.
# Concept files: markdown with YAML frontmatter (type, title, ...) and
# '## Heading' body sections. Unknown keys/types are tolerated.
memory_dir = '$MEMORY_DIR'

def read_concepts(layer):
    d = os.path.join(memory_dir, layer)
    out = []
    if not os.path.isdir(d):
        return out
    for name in sorted(os.listdir(d)):
        if not name.endswith('.md') or name in ('index.md', 'log.md'):
            continue
        try:
            with open(os.path.join(d, name)) as f:
                lines = f.read().splitlines()
        except Exception:
            continue
        c = {'_file': name}
        i = 0
        if lines and lines[0].strip() == '---':
            i = 1
            while i < len(lines) and lines[i].strip() != '---':
                line = lines[i]
                if ':' in line and not line.startswith((' ', chr(9), '-', '#')):
                    k, _, v = line.partition(':')
                    v = v.strip()
                    if len(v) >= 2 and v[0] == v[-1] and v[0] in '\'\"':
                        v = v[1:-1]
                    c[k.strip()] = v
                i += 1
            i += 1
        sec = None
        for line in lines[i:]:
            if line.startswith('## '):
                sec = 'section:' + line[3:].strip().lower()
            elif sec and line.strip():
                c.setdefault(sec, line.strip())
        out.append(c)
    out.sort(key=lambda c: (c.get('timestamp', ''), c['_file']))
    return out

# Last 3 failures (title = approach, root cause from body section)
try:
    fails = read_concepts('failures')[-3:]
    if fails:
        avoid = [f\"{c.get('title', c['_file'])} ({c.get('section:root cause', '?')})\" for c in fails]
        context_parts.append('Avoid: ' + '; '.join(avoid))
except Exception:
    pass

# Learned rules (active only, titles only)
try:
    rules = [c.get('title', c['_file']) for c in read_concepts('rules')
             if str(c.get('active', 'true')).lower() != 'false'][:5]
    if rules:
        context_parts.append('Rules: ' + '; '.join(rules))
except Exception:
    pass

# Build output JSON (keep under 500 chars for token efficiency)
additional = ' | '.join(context_parts)
if len(additional) > 500:
    additional = additional[:497] + '...'

output = {
    'hookSpecificOutput': {
        'hookEventName': 'SubagentStart',
        'additionalContext': additional
    }
} if additional else {}

print(json.dumps(output))
" 2>/dev/null || echo '{}')
else
    CONTEXT='{}'
fi

echo "$CONTEXT"
exit 0
