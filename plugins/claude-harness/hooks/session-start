#!/bin/bash
# Claude Harness SessionStart Hook
#
# Uses the native session identity Claude Code provides on stdin
# (session_id, source, transcript_path) instead of generating one.
# Keeps injected context lean: full briefing lives in
# .claude-harness/session-briefing.md and is read on demand.

INPUT=$(cat)

HARNESS_DIR="$CLAUDE_PROJECT_DIR/.claude-harness"

# --- Parse hook stdin (session_id, source, transcript_path) ---
SESSION_ID=""; SOURCE="startup"; TRANSCRIPT_PATH=""
if command -v jq >/dev/null 2>&1; then
    SESSION_ID=$(printf '%s' "$INPUT" | jq -r '.session_id // empty' 2>/dev/null)
    SOURCE=$(printf '%s' "$INPUT" | jq -r '.source // "startup"' 2>/dev/null)
    TRANSCRIPT_PATH=$(printf '%s' "$INPUT" | jq -r '.transcript_path // empty' 2>/dev/null)
elif command -v python3 >/dev/null 2>&1; then
    PARSED=$(printf '%s' "$INPUT" | python3 -c '
import json, sys
try:
    d = json.load(sys.stdin)
except Exception:
    d = {}
print(d.get("session_id", ""))
print(d.get("source", "startup") or "startup")
print(d.get("transcript_path", ""))
' 2>/dev/null)
    SESSION_ID=$(printf '%s' "$PARSED" | sed -n 1p)
    SOURCE=$(printf '%s' "$PARSED" | sed -n 2p)
    TRANSCRIPT_PATH=$(printf '%s' "$PARSED" | sed -n 3p)
fi
# Fallback for very old Claude Code versions that pass no session_id
[ -n "$SESSION_ID" ] || SESSION_ID="sess-$(date +%s%N | sha256sum | head -c 16)"
[ -n "$SOURCE" ] || SOURCE="startup"

# On resume the conversation context is retained - nothing to (re)inject.
if [ "$SOURCE" = "resume" ]; then
    exit 0
fi

# --- JSON output helper (jq preferred, python3 fallback) ---
emit_output() {
    local MSG="$1" CTX="$2"
    if command -v jq >/dev/null 2>&1; then
        jq -n --arg msg "$MSG" --arg ctx "$CTX" '{
            continue: true,
            systemMessage: $msg,
            hookSpecificOutput: { hookEventName: "SessionStart", additionalContext: $ctx }
        }'
    else
        MSG="$MSG" CTX="$CTX" python3 -c '
import json, os
print(json.dumps({
    "continue": True,
    "systemMessage": os.environ["MSG"],
    "hookSpecificOutput": {"hookEventName": "SessionStart", "additionalContext": os.environ["CTX"]},
}))'
    fi
}

# --- First-time detection: suggest setup if harness not initialized ---
if [ ! -d "$HARNESS_DIR" ]; then
    emit_output "Claude Harness is not initialized in this project. Run /claude-harness:setup to get started." ""
    exit 0
fi

# --- Version (SHA-based) ---
PLUGIN_VERSION=$(cd "$CLAUDE_PLUGIN_ROOT" && git rev-parse --short HEAD 2>/dev/null || basename "$CLAUDE_PLUGIN_ROOT" | cut -c1-12)

# --- Run setup.sh only when the plugin version changed (stamp-gated) ---
# setup.sh is idempotent but not free; the stamp makes session start O(1).
STAMP_FILE="$HARNESS_DIR/.setup-stamp"
if [ "$SOURCE" = "startup" ] && [ "$(cat "$STAMP_FILE" 2>/dev/null)" != "$PLUGIN_VERSION" ]; then
    bash "$CLAUDE_PLUGIN_ROOT/setup.sh" >/dev/null 2>&1 || true
    echo "$PLUGIN_VERSION" > "$STAMP_FILE" 2>/dev/null || true
fi

# --- Session state dir (keyed by the NATIVE session id) ---
SESSIONS_DIR="$HARNESS_DIR/sessions"
SESSION_DIR="$SESSIONS_DIR/$SESSION_ID"
RECOVERY_DIR="$SESSIONS_DIR/.recovery"
mkdir -p "$SESSION_DIR"
if [ ! -f "$SESSION_DIR/session.json" ] || [ "$SOURCE" = "startup" ]; then
    cat > "$SESSION_DIR/session.json" << SESSIONEOF
{ "id": "$SESSION_ID", "startedAt": "$(date -u +%Y-%m-%dT%H:%M:%SZ)", "source": "$SOURCE", "transcriptPath": "$TRANSCRIPT_PATH", "workingDir": "$CLAUDE_PROJECT_DIR" }
SESSIONEOF
fi

# --- Stale session cleanup (startup only) ---
# A session is stale when its recorded transcript no longer exists or has
# not been touched for 24h. (Liveness by PID is impossible here: the hook
# process exits immediately, so any PID recorded at start is always dead.)
if [ "$SOURCE" = "startup" ]; then
    for sd in "$SESSIONS_DIR"/*/; do
        [ -d "$sd" ] || continue
        sid=$(basename "$sd")
        [ "$sid" = "$SESSION_ID" ] && continue
        [ "$sid" = ".recovery" ] && continue
        sf="$sd/session.json"
        tp=""
        [ -f "$sf" ] && tp=$(grep -o '"transcriptPath"[[:space:]]*:[[:space:]]*"[^"]*"' "$sf" 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/')
        STALE=false
        if [ -z "$tp" ] || [ ! -f "$tp" ]; then
            STALE=true
        elif [ -n "$(find "$tp" -mmin +1440 2>/dev/null)" ]; then
            STALE=true
        fi
        [ "$STALE" = true ] || continue
        # Rescue an interrupted loop before removing the stale dir
        lf="$sd/loop-state.json"
        if [ -f "$lf" ]; then
            ls_val=$(grep -o '"status"[[:space:]]*:[[:space:]]*"[^"]*"' "$lf" 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/')
            if [ "$ls_val" = "in_progress" ]; then
                lfeat=$(grep -o '"feature"[[:space:]]*:[[:space:]]*"[^"]*"' "$lf" 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/')
                latmp=$(grep -o '"attempt"[[:space:]]*:[[:space:]]*[0-9]*' "$lf" 2>/dev/null | head -1 | sed 's/.*: *\([0-9]*\).*/\1/')
                lphase=$(grep -o '"phase"[[:space:]]*:[[:space:]]*"[^"]*"' "$lf" 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/')
                mkdir -p "$RECOVERY_DIR"
                cat > "$RECOVERY_DIR/interrupted.json" << INTEOF
{ "version":1, "interruptedAt":"$(date -u +%Y-%m-%dT%H:%M:%SZ)", "staleSessionId":"$sid", "feature":"$lfeat", "attemptAtInterrupt":${latmp:-1}, "tddPhase":"${lphase:-null}", "reason":"stale-session-detected" }
INTEOF
                cp "$lf" "$RECOVERY_DIR/loop-state.json" 2>/dev/null
                [ -f "$sd/autonomous-state.json" ] && cp "$sd/autonomous-state.json" "$RECOVERY_DIR/autonomous-state.json" 2>/dev/null
            fi
        fi
        rm -rf "$sd"
    done
fi

# --- GitHub repo caching ---
GITHUB_OWNER=""; GITHUB_REPO=""
REMOTE_URL=$(git remote get-url origin 2>/dev/null)
if [ -n "$REMOTE_URL" ]; then
    if [[ "$REMOTE_URL" =~ git@github\.com:([^/]+)/([^/.]+) ]]; then
        GITHUB_OWNER="${BASH_REMATCH[1]}"; GITHUB_REPO="${BASH_REMATCH[2]}"
    elif [[ "$REMOTE_URL" =~ github\.com/([^/]+)/([^/.]+) ]]; then
        GITHUB_OWNER="${BASH_REMATCH[1]}"; GITHUB_REPO="${BASH_REMATCH[2]}"
    fi
    GITHUB_REPO="${GITHUB_REPO%.git}"
fi

# --- Feature summary (compact, via shared compiler) ---
FEATURE_LINES=""
if command -v python3 >/dev/null 2>&1; then
    FEATURE_LINES=$(python3 "$CLAUDE_PLUGIN_ROOT/scripts/compile-briefing.py" "$HARNESS_DIR" --features-only 2>/dev/null || true)
fi

FEATURES_FILE="$HARNESS_DIR/features/active.json"
PENDING_FEATURES=0; IN_PROGRESS=0
if [ -f "$FEATURES_FILE" ]; then
    PENDING_FEATURES=$(grep -c '"status"[[:space:]]*:[[:space:]]*"pending"' "$FEATURES_FILE" 2>/dev/null | head -1 || echo "0")
    IN_PROGRESS=$(grep -c '"status"[[:space:]]*:[[:space:]]*"in_progress"' "$FEATURES_FILE" 2>/dev/null | head -1 || echo "0")
fi

# --- Interrupt / loop banners ---
INT_FEATURE=""; INT_ATTEMPT=""; INT_PHASE=""
if [ -f "$RECOVERY_DIR/interrupted.json" ]; then
    INT_FEATURE=$(grep -o '"feature"[[:space:]]*:[[:space:]]*"[^"]*"' "$RECOVERY_DIR/interrupted.json" 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/')
    INT_ATTEMPT=$(grep -o '"attemptAtInterrupt"[[:space:]]*:[[:space:]]*[0-9]*' "$RECOVERY_DIR/interrupted.json" 2>/dev/null | head -1 | sed 's/.*: *\([0-9]*\).*/\1/')
    INT_PHASE=$(grep -o '"tddPhase"[[:space:]]*:[[:space:]]*"[^"]*"' "$RECOVERY_DIR/interrupted.json" 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/')
fi

LOOP_FILE="$SESSION_DIR/loop-state.json"
LOOP_FEATURE=""; LOOP_STATUS=""; LOOP_ATTEMPT=""; LOOP_MAX=""
if [ -f "$LOOP_FILE" ]; then
    LOOP_STATUS=$(grep -o '"status"[[:space:]]*:[[:space:]]*"[^"]*"' "$LOOP_FILE" 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/')
    if [ "$LOOP_STATUS" = "in_progress" ]; then
        LOOP_FEATURE=$(grep -o '"feature"[[:space:]]*:[[:space:]]*"[^"]*"' "$LOOP_FILE" 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/')
        LOOP_ATTEMPT=$(grep -o '"attempt"[[:space:]]*:[[:space:]]*[0-9]*' "$LOOP_FILE" 2>/dev/null | head -1 | sed 's/.*: *\([0-9]*\).*/\1/')
        LOOP_MAX=$(grep -o '"maxAttempts"[[:space:]]*:[[:space:]]*[0-9]*' "$LOOP_FILE" 2>/dev/null | head -1 | sed 's/.*: *\([0-9]*\).*/\1/')
    fi
fi

# --- Build lean Claude context ---
CTX="=== CLAUDE HARNESS SESSION (v$PLUGIN_VERSION) ===
Session ID: $SESSION_ID
Session state dir: .claude-harness/sessions/$SESSION_ID/"

if [ -n "$GITHUB_OWNER" ] && [ -n "$GITHUB_REPO" ]; then
    CTX="$CTX
GitHub (cached): $GITHUB_OWNER/$GITHUB_REPO - reuse for all gh calls, do NOT re-parse git remote."
fi

CTX="$CTX
Features: $PENDING_FEATURES pending, $IN_PROGRESS in progress."
[ -n "$FEATURE_LINES" ] && CTX="$CTX
$FEATURE_LINES"

if [ -n "$INT_FEATURE" ]; then
    CTX="$CTX

*** INTERRUPTED SESSION DETECTED ***
Feature $INT_FEATURE was interrupted at attempt ${INT_ATTEMPT:-?} (phase: ${INT_PHASE:-unknown}).
Resume with /claude-harness:flow $INT_FEATURE - it will offer recovery options. Do NOT retry the same approach blindly."
fi

if [ -n "$LOOP_FEATURE" ]; then
    CTX="$CTX

ACTIVE LOOP: $LOOP_FEATURE (attempt $LOOP_ATTEMPT/$LOOP_MAX). Resume: /claude-harness:flow $LOOP_FEATURE"
fi

CTX="$CTX

Before starting harness work (flow/checkpoint/merge), read .claude-harness/session-briefing.md for full context (recent decisions, approaches to avoid, learned rules)."

# --- Build compact user-visible message ---
STATUS_LINE="P:$PENDING_FEATURES WIP:$IN_PROGRESS"
[ -n "$INT_FEATURE" ] && STATUS_LINE="$STATUS_LINE | INTERRUPTED: $INT_FEATURE"
[ -n "$LOOP_FEATURE" ] && STATUS_LINE="$STATUS_LINE | ACTIVE: $LOOP_FEATURE ($LOOP_ATTEMPT/$LOOP_MAX)"
MSG="Claude Harness v$PLUGIN_VERSION | $STATUS_LINE | /claude-harness:flow to start"

emit_output "$MSG" "$CTX"
