#!/bin/bash
# Claude Harness PreCompact Hook
# Saves critical state before context compaction to prevent data loss.

# Safety net: ensure hook NEVER exits non-zero
trap 'exit 0' ERR

HARNESS_DIR="$CLAUDE_PROJECT_DIR/.claude-harness"

# Skip if not a harness project
if [ ! -d "$HARNESS_DIR" ]; then
    echo '{"continue": true}'
    exit 0
fi

TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z")

# ============================================================================
# SAVE EMERGENCY STATE BEFORE COMPACTION
# ============================================================================

BACKUP_DIR="$HARNESS_DIR/memory/compaction-backups"
mkdir -p "$BACKUP_DIR"
BACKUP_FILE="$BACKUP_DIR/pre-compact-$(date +%Y%m%d-%H%M%S).json"

# Loop state: first in_progress loop across session dirs
LOOP_STATE="null"
for sd in "$HARNESS_DIR/sessions"/*/; do
    [ -d "$sd" ] || continue
    [ "$(basename "$sd")" = ".recovery" ] && continue
    lf="$sd/loop-state.json"
    [ -f "$lf" ] || continue
    if command -v jq >/dev/null 2>&1; then
        st=$(jq -r '.status // empty' "$lf" 2>/dev/null) || st=""
        if [ "$st" = "in_progress" ]; then
            LOOP_STATE=$(jq '.' "$lf" 2>/dev/null) || LOOP_STATE="null"
            break
        fi
    fi
done

PROGRESS="null"
if [ -f "$HARNESS_DIR/claude-progress.json" ] && command -v jq >/dev/null 2>&1; then
    PROGRESS=$(jq '.' "$HARNESS_DIR/claude-progress.json" 2>/dev/null) || PROGRESS="null"
fi

GIT_BRANCH=$(git branch --show-current 2>/dev/null || echo "unknown")
GIT_LAST_COMMIT=$(git log -1 --format="%h %s" 2>/dev/null || echo "unknown")
UNCOMMITTED_COUNT=$(git status --porcelain 2>/dev/null | grep -c '.' 2>/dev/null || echo "0")

if command -v jq >/dev/null 2>&1; then
    jq -n \
        --arg ts "$TIMESTAMP" \
        --arg branch "$GIT_BRANCH" \
        --arg commit "$GIT_LAST_COMMIT" \
        --argjson files "${UNCOMMITTED_COUNT:-0}" \
        --argjson loop "$LOOP_STATE" \
        --argjson progress "$PROGRESS" \
        '{
            timestamp: $ts,
            reason: "pre-compaction-safety-backup",
            git: { branch: $branch, lastCommit: $commit, uncommittedFiles: $files },
            loopState: $loop,
            progress: $progress
        }' > "$BACKUP_FILE" 2>/dev/null
else
    cat > "$BACKUP_FILE" << BACKUP_EOF
{
  "timestamp": "$TIMESTAMP",
  "reason": "pre-compaction-safety-backup",
  "git": { "branch": "$GIT_BRANCH", "lastCommit": "$GIT_LAST_COMMIT", "uncommittedFiles": ${UNCOMMITTED_COUNT:-0} }
}
BACKUP_EOF
fi

# Keep only last 5 backups to avoid bloat
ls -t "$BACKUP_DIR"/pre-compact-*.json 2>/dev/null | tail -n +6 | xargs rm -f 2>/dev/null

# ============================================================================
# OUTPUT FOR CLAUDE (kept short - this lands in the compacted context)
# ============================================================================

CLAUDE_CONTEXT="Harness state backed up before compaction (branch: $GIT_BRANCH, last commit: $GIT_LAST_COMMIT).
Memory layers are on disk and unaffected. If context feels incomplete after compaction, read .claude-harness/session-briefing.md."

if command -v jq >/dev/null 2>&1; then
    jq -n --arg ctx "$CLAUDE_CONTEXT" '{
        continue: true,
        hookSpecificOutput: { hookEventName: "PreCompact", additionalContext: $ctx }
    }'
else
    CTX="$CLAUDE_CONTEXT" python3 -c '
import json, os
print(json.dumps({
    "continue": True,
    "hookSpecificOutput": {"hookEventName": "PreCompact", "additionalContext": os.environ["CTX"]},
}))' 2>/dev/null || echo '{"continue": true}'
fi
